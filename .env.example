# ===========================================
# APEC Schedule - Production Environment
# ===========================================
# Copy this file to .env and fill in real values
# NEVER commit .env to git!

# Flask Settings
FLASK_ENV=production
FLASK_DEBUG=0

# Security - GENERATE YOUR OWN KEY!
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-new-one

# Database
# SQLite (for small loads):
DATABASE_URL=sqlite:///instance/college.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/college_schedule

# MySQL:
# DATABASE_URL=mysql://user:password@localhost:3306/college_schedule

# Authentication - MUST enable and change password!
AUTH_ENABLED=true
AUTH_USERNAME=admin@apec.edu.kz
AUTH_PASSWORD=CHANGE_THIS_PASSWORD_IMMEDIATELY

# Google Sheets Integration (optional)
GOOGLE_SHEETS_AUTO_SYNC=false
GOOGLE_SHEETS_SIMPLE_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
